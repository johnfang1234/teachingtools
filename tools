<script>
    const ratio = 4/3; 
    let flipped=false, seatList=[];
    let currentMode='m3', selectSeat=null, currentClass='none'; 
    const groupColors = ['gc1','gc2','gc3','gc4','gc5','gc6'];

    let dragElement = null, pointerId = null;
    let startX = 0, startY = 0, originalLeft = 0, originalTop = 0;
    const snapThreshold = 15; 
    let isEditingMode = false; 

    let poolUnpicked = [];      
    let lastEightPicked = [];   
    let pickCounter = 0;        
    let isReturnShotMode = false; 
    let isRolling = false;      

    // 用于追踪已被抽取高亮过的物理小组历史，轮完后自动重置
    let pickedPhysicalGroupsHistory = [];

    // 内存临时留存Group Maker当前拆分的小组名单数组数据，供动态无损加减组使用
    let currentActiveGroupsData = [];

const defaultClassData = {};

    let classData = {...defaultClassData};
    let savedLayouts = {};

    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    
    function playTickSound() {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(580, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.06, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.04);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.05);
    }

    function playSuccessSound() {
        const now = audioCtx.currentTime;
        [523.25, 659.25, 783.99].forEach((freq, idx) => {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = 'triangle';
            osc.frequency.setValueAtTime(freq, now + idx * 0.06);
            gain.gain.setValueAtTime(0.12, now + idx * 0.06);
            gain.gain.exponentialRampToValueAtTime(0.001, now + idx * 0.06 + 0.3);
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.start(now + idx * 0.06);
            osc.stop(now + idx * 0.06 + 0.35);
        });
    }

    // ── 🎲 Dice Roll Sound — realistic rattling ──
    function playDiceRollSound() {
        const now = audioCtx.currentTime;
        // Multiple impact hits simulating dice bouncing on table
        const hitTimes = [0, 0.09, 0.17, 0.24, 0.30, 0.35, 0.39, 0.42, 0.44, 0.46];
        hitTimes.forEach((t, i) => {
            const hitTime = now + t;
            // Noise burst (die body impact)
            const bufSize = Math.floor(audioCtx.sampleRate * 0.025);
            const buf = audioCtx.createBuffer(1, bufSize, audioCtx.sampleRate);
            const data = buf.getChannelData(0);
            for (let j = 0; j < bufSize; j++) data[j] = (Math.random() * 2 - 1);
            const src = audioCtx.createBufferSource();
            src.buffer = buf;
            // High-pass + low-pass to get that hard clack of plastic/wood
            const hp = audioCtx.createBiquadFilter();
            hp.type = 'highpass';
            hp.frequency.value = 900 + Math.random() * 400;
            const lp = audioCtx.createBiquadFilter();
            lp.type = 'lowpass';
            lp.frequency.value = 5000;
            const gain = audioCtx.createGain();
            // Decay volume — later hits are quieter (settling)
            const vol = 0.22 * (1 - i * 0.07);
            gain.gain.setValueAtTime(0, hitTime);
            gain.gain.linearRampToValueAtTime(vol, hitTime + 0.004);
            gain.gain.exponentialRampToValueAtTime(0.001, hitTime + 0.028);
            src.connect(hp); hp.connect(lp); lp.connect(gain); gain.connect(audioCtx.destination);
            src.start(hitTime); src.stop(hitTime + 0.03);

            // Resonant body thump underneath each hit
            const osc = audioCtx.createOscillator();
            const ogain = audioCtx.createGain();
            osc.type = 'sine';
            osc.frequency.setValueAtTime(200 + Math.random() * 80, hitTime);
            osc.frequency.exponentialRampToValueAtTime(80, hitTime + 0.025);
            const tVol = 0.12 * (1 - i * 0.08);
            ogain.gain.setValueAtTime(0, hitTime);
            ogain.gain.linearRampToValueAtTime(tVol, hitTime + 0.003);
            ogain.gain.exponentialRampToValueAtTime(0.001, hitTime + 0.03);
            osc.connect(ogain); ogain.connect(audioCtx.destination);
            osc.start(hitTime); osc.stop(hitTime + 0.035);
        });
    }

    // ── 🎲 Dice Overlay Logic — verified ol/li approach ──
    const diceOverlay = document.getElementById('diceOverlay');
    const dieList = document.getElementById('dieList');
    const diceBigNumber = document.getElementById('diceBigNumber');
    let diceRolling = false;
    let diceRollCount = 0;

    // landTransforms: for rollCount N and result R, the container transform that shows face R
    // Mathematically verified: all 6 faces return z≈1.0 in view space
    // Side CSS: side1=rotY(0), side2=rotY(-90), side3=rotX(90), side4=rotX(-90), side5=rotY(90), side6=rotY(180)
    // Container inverse + spin offset of rollCount*360 on both axes:
    function getLandTransform(rollN, result) {
        const s = rollN * 360;
        const transforms = {
            1: `translateZ(-80px) rotateX(${s}deg) rotateY(${s+0}deg)`,
            2: `translateZ(-80px) rotateX(${s}deg) rotateY(${s+90}deg)`,
            3: `translateZ(-80px) rotateX(${s-90}deg) rotateY(${s}deg)`,
            4: `translateZ(-80px) rotateX(${s+90}deg) rotateY(${s}deg)`,
            5: `translateZ(-80px) rotateX(${s}deg) rotateY(${s-90}deg)`,
            6: `translateZ(-80px) rotateX(${s}deg) rotateY(${s+180}deg)`,
        };
        return transforms[result];
    }

    function rollDice() {
        if (diceRolling) return;
        diceRolling = true;
        diceRollCount++;
        const result = Math.floor(Math.random() * 6) + 1;
        diceBigNumber.style.opacity = '0';
        playDiceRollSound();
        dieList.style.transition = 'transform 1.1s ease-out';
        dieList.style.transform = getLandTransform(diceRollCount, result);
        setTimeout(() => {
            diceBigNumber.textContent = result;
            diceBigNumber.style.opacity = '1';
            diceRolling = false;
        }, 1150);
    }

    document.getElementById('diceBtn').onclick = () => { diceOverlay.classList.add('active'); };
    document.getElementById('diceScene').onclick = rollDice;
    document.getElementById('diceCloseBtn').onclick = () => {
        diceOverlay.classList.remove('active');
        diceRolling = false;
    };

    // ── 🆕 全屏图形化环形计时器核心驱动代码（Pacman吃豆人升级版） ──
    let timerInterval = null;
    let timerTotalSeconds = 300; 
    let timerPresetDuration = 300; 
    const timerOverlay = document.getElementById('timerOverlay');
    const timerCircleProgress = document.getElementById('timerCircleProgress');
    const timerMinSpan = document.getElementById('timerMinSpan');
    const timerSecSpan = document.getElementById('timerSecSpan');
    const timerMinInput = document.getElementById('timerMinInput');
    const timerTitleInput = document.getElementById('timerTitleInput');
    
    function updateTimerDisplay() {
        const m = Math.floor(timerTotalSeconds / 60);
        const s = timerTotalSeconds % 60;
        timerMinSpan.textContent = String(m).padStart(2, '0');
        timerSecSpan.textContent = String(s).padStart(2, '0');
        
        // 圆弧进度条：用 stroke-dashoffset 实现逐渐缩短的弧
        const r = 148;
        const circumference = 2 * Math.PI * r;
        timerCircleProgress.style.strokeDasharray = circumference;
        if (timerPresetDuration <= 0 || timerTotalSeconds <= 0) {
            timerCircleProgress.style.strokeDashoffset = circumference;
        } else {
            const percent = timerTotalSeconds / timerPresetDuration;
            timerCircleProgress.style.strokeDashoffset = circumference * (1 - percent);
        }

        // 临近结束时变红，平时为标准色
        if (timerTotalSeconds <= 10 && timerTotalSeconds > 0) {
            timerCircleProgress.style.stroke = "var(--coral)";
        } else {
            timerCircleProgress.style.stroke = "var(--teal-mid)";
        }
    }
    
    // 点击分钟文本：直接内联高亮可编辑，不再弹框/切换
    let timerMinEditing = false;
    timerMinSpan.onclick = function() {
        if (timerInterval) return; // 运行中禁止编辑
        if (timerMinEditing) return;
        timerMinEditing = true;
        timerMinSpan.contentEditable = 'true';
        timerMinSpan.classList.add('editing');
        timerMinSpan.focus();
        // 全选文字
        const range = document.createRange();
        range.selectNodeContents(timerMinSpan);
        const sel = window.getSelection();
        sel.removeAllRanges();
        sel.addRange(range);
    };

    function commitMinInput() {
        if (!timerMinEditing) return;
        timerMinEditing = false;
        timerMinSpan.contentEditable = 'false';
        timerMinSpan.classList.remove('editing');
        let val = parseInt(timerMinSpan.textContent);
        if (isNaN(val) || val < 0) val = 0;
        const s = timerTotalSeconds % 60;
        timerTotalSeconds = val * 60 + s;
        timerPresetDuration = timerTotalSeconds;
        updateTimerDisplay();
    }

    timerMinSpan.onblur = commitMinInput;
    timerMinSpan.onkeydown = (e) => {
        if (e.key === 'Enter') { e.preventDefault(); commitMinInput(); }
        // 只允许数字键、退格、方向键
