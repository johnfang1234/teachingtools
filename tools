        const dynamicSeatPool = seatList.filter(s => s.el.querySelector('.seat-name').innerText.trim() !== '');
        if (dynamicSeatPool.length === 0) { alert("No students found on the seating chart."); return; }
        
        seatList.forEach(s => s.el.classList.remove('group-selected', 'group-rolling'));

        let targetName = "";
        const activeNames = dynamicSeatPool.map(s => s.el.querySelector('.seat-name').innerText.trim());
        poolUnpicked = poolUnpicked.filter(n => activeNames.includes(n));

        if (poolUnpicked.length === 0) { poolUnpicked = [...activeNames]; lastEightPicked = []; pickCounter = 0; isReturnShotMode = false; }

        if (isReturnShotMode && lastEightPicked.length > 0) {
            const validRePick = lastEightPicked.filter(n => activeNames.includes(n));
            const rePickPool = validRePick.length > 0 ? validRePick : activeNames;
            const rIdx = Math.floor(Math.random() * rePickPool.length); targetName = rePickPool[rIdx];
