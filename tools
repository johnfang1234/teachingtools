    function recalculateAbsoluteSizes() {
        if (seatList.length === 0) return;
        const sampleSeat = seatList[0]; const cardH = sampleSeat.h;
        const tagSize = Math.max(18, cardH * 0.26); const tagFontSize = tagSize * 0.58;
        const baseNameFontSize = currentMode === 'custom' ? Math.min(36, cardH * 0.45) : Math.min(32, cardH * 0.35); let finalFontSize = baseNameFontSize;

        if (currentMode === 'custom') {
            let minScale = 1;
            seatList.forEach(s => {
                const nameEl = s.el.querySelector('.seat-name');
                if (nameEl) {
                    nameEl.style.fontSize = `${baseNameFontSize}px`; nameEl.style.transform = 'scale(1)';
                    const containerWidth = nameEl.offsetWidth; const scrollWidth = nameEl.scrollWidth;
                    if (scrollWidth > 0 && containerWidth > 0) { const currentScale = (containerWidth / scrollWidth) * 0.88; if (currentScale < minScale) { minScale = currentScale; } }
                }
            });
            finalFontSize = baseNameFontSize * minScale;
        }

        seatList.forEach(s => {
            const tagEl = s.el.querySelector('.num-tag'); const nameEl = s.el.querySelector('.seat-name');
            if (tagEl) { tagEl.style.width = `${tagSize}px`; tagEl.style.height = `${tagSize}px`; tagEl.style.fontSize = `${tagFontSize}px`; }
            if (nameEl) {
                if (currentMode === 'custom') { nameEl.style.fontSize = `${finalFontSize}px`; nameEl.style.transform = 'scale(1)'; } 
                else {
                    nameEl.style.fontSize = `${baseNameFontSize}px`; nameEl.style.transform = 'scale(1)';
                    const containerWidth = nameEl.offsetWidth; const scrollWidth = nameEl.scrollWidth;
                    if (scrollWidth > containerWidth) { const shrinkRatio = (containerWidth / scrollWidth) * 0.97; nameEl.style.transform = `scale(${shrinkRatio})`; }
                }
            }
        });
    }

    function shuffleNames(){
        let names=seatList.map(s=>s.el.querySelector('.seat-name').innerText).filter(n=>n); if(!names.length) return;
