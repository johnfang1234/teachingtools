    function layoutFourPerson(bw, bh) {
        const innerGap = bw * 0.01, groupGapX = bw * 0.04, groupGapY = bh * 0.05;
        const w = (bw * 0.92 - (3 * innerGap + 2 * groupGapX)) / 6;
        const h = Math.min(w / ratio, (bh * 0.90 - groupGapY) / 4); const realW = h * ratio;
        const startX = (bw - (3 * (2 * realW + innerGap) + 2 * groupGapX)) / 2; const startY = (bh - (2 * (2 * h + innerGap) + groupGapY)) / 2;
        let idx=0, gIdx=0;
        for(let r=0; r<2; r++) for(let c=0; c<3; c++){
            const bx = startX + c * (2 * realW + innerGap + groupGapX); const by = startY + r * (2 * h + innerGap + groupGapY);
            const col = groupColors[gIdx % 6]; gIdx++;
            createSeat(idx++, bx, by, realW, h, col); createSeat(idx++, bx + realW + innerGap, by, realW, h, col);
            createSeat(idx++, bx, by + h + innerGap, realW, h, col); createSeat(idx++, bx + realW + innerGap, by + h + innerGap, realW, h, col);
        }
    }

    function layoutSixPerson(bw, bh) {
        const innerGap = bw * 0.01, groupGap = bw * 0.05;
        const w = (bw * 0.92 - (4 * innerGap + groupGap)) / 6;
        const h = Math.min(w / ratio, (bh * 0.90 - innerGap - groupGap) / 4); const realW = h * ratio;
        const gw = 3 * realW + 2 * innerGap; const gh = 2 * h + innerGap;
        const sx = (bw - 2 * gw - groupGap) / 2; const sy = (bh - 2 * gh - groupGap) / 2;
        let idx=0, gIdx=0;
        [[sx,sy],[sx+gw+groupGap,sy],[sx,sy+gh+groupGap],[sx+gw+groupGap,sy+gh+groupGap]].forEach(p=>{
            const col = groupColors[gIdx % 6]; gIdx++;
            for(let i=0; i<2; i++) for(let j=0; j<3; j++) { createSeat(idx++, p[0] + j * (realW + innerGap), p[1] + i * (h + innerGap), realW, h, col); }
        });
    }

    function layoutDoublePair(bw, bh) {
        const pairGap = bw * 0.01, colGap = bw * 0.07, rowGap = bh * 0.03;
        const w = (bw * 0.92 - (3 * pairGap + 2 * colGap)) / 6;
        const h = Math.min(w / ratio, (bh * 0.92 - 3 * rowGap) / 4); const realW = h * ratio;
        const sx = (bw - 3 * (2 * realW + pairGap) - 2 * colGap) / 2; const sy = (bh - 4 * h - 3 * rowGap) / 2;
        let idx=0, gIdx=0;
        for(let c=0; c<3; c++){
            const bx = sx + c * (2 * realW + pairGap + colGap);
            for(let r=0; r<4; r++){
                const col = groupColors[(gIdx + r) % 6]; const by = sy + r * (h + rowGap);
                createSeat(idx++, bx, by, realW, h, col); createSeat(idx++, bx + realW + pairGap, by, realW, h, col);
            }
            gIdx += 2;
        }
    }

    function layoutThreeRow(bw, bh) {
        const seatGap = bw * 0.012, rowGap = bh * 0.025, groupGap = bw * 0.06;
        const colNum = 3, rowNum = 4;
        const w = (bw * 0.92 - (2 * (colNum - 1) * seatGap + groupGap)) / (2 * colNum);
        const h = Math.min(w / ratio, (bh * 0.92 - (rowNum - 1) * rowGap) / rowNum); const realW = h * ratio;
        const gw = colNum * realW + (colNum - 1) * seatGap; const sy = (bh - (rowNum * h + (rowNum - 1) * rowGap)) / 2;
        const mid = bw / 2; let idx=0, gIdx=0;
        for(let g=0; g<2; g++){
            const sx = g === 0 ? mid - gw - groupGap / 2 : mid + groupGap / 2;
            for(let r=0; r<rowNum; r++){
                const col = groupColors[gIdx % 6]; const y = sy + r * (h + rowGap);
                for(let c=0; c<colNum; c++) createSeat(idx++, sx + c * (realW + seatGap), y, realW, h, col);
                gIdx++;
            }
        }
    }

    function createSeat(id, x, y, w, h, colorClass, name=""){
        if (currentMode === 'custom') { w = w * 0.75; h = h * 0.75; }
