                        // Timer settings
                        if (s.timer) {
                            if (s.timer.presetDuration) { timerPresetDuration = s.timer.presetDuration; timerTotalSeconds = s.timer.presetDuration; updateTimerDisplay(); }
                            if (s.timer.title && document.getElementById('timerTitleInput')) document.getElementById('timerTitleInput').value = s.timer.title;
                        }
                        // Whiteboard settings
                        if (s.whiteboard) {
                            const dtEl = document.getElementById('directionsTextarea');
                            const dfEl = document.getElementById('dirFontSelect');
                            const dsEl = document.getElementById('dirSizeSelect');
                            if (s.whiteboard.content && dtEl) dtEl.innerHTML = s.whiteboard.content;
                            if (s.whiteboard.font && dfEl) { dfEl.value = s.whiteboard.font; if (dtEl) dtEl.style.fontFamily = s.whiteboard.font; }
                            if (s.whiteboard.size && dsEl) { dsEl.value = s.whiteboard.size; if (dtEl) dtEl.style.fontSize = s.whiteboard.size; }
                        }
                        // Group Maker settings
                        if (s.groupMaker && s.groupMaker.groupSize) {
                            chosenGroupSize = s.groupMaker.groupSize;
                            document.querySelectorAll('.btn-gsize').forEach(b => {
                                b.classList.toggle('selected', parseInt(b.dataset.size) === chosenGroupSize);
                            });
                        }
                        // Restore mode and class
                        if (s.currentMode) { currentMode = s.currentMode; if (document.getElementById('modeSelect')) document.getElementById('modeSelect').value = s.currentMode; }
                        if (s.flipped !== undefined && s.flipped !== flipped) { flipBtn.click(); }
                    }
                } else if (parsedData && typeof parsedData === 'object') {
                    savedLayouts = parsedData;
                } else { alert("Invalid file format."); return; }
                localStorage.setItem(STORAGE_LAYOUTS_KEY, JSON.stringify(savedLayouts));
                localStorage.setItem(STORAGE_CLASSDATA_KEY, JSON.stringify(classData));
                alert("Imported successfully!");
                populateClassSelect(parsedData.settings && parsedData.settings.currentClass ? parsedData.settings.currentClass : 'none');
                initSeat(currentMode);
            } catch (err) { alert("Failed to parse file."); }
        };
        reader.readAsText(file); fileInput.value = ''; 
    };

    window.onresize = () => { const saveKey = `${currentClass}_${currentMode}`; if(currentClass!=='none' && currentMode !== 'custom') { savedLayouts[saveKey] = null; } initSeat(currentMode); };
    window.onload = () => { populateClassSelect('none'); initSeat('m3'); };

    // ── Todo：打开独立网页 ────────────────────────────────────────────────
    const todoBtn = document.getElementById('todoBtn');
    if (todoBtn) {
        todoBtn.onclick = () => {
            const url = 'https://johnfang1234.github.io/teachingtools/todo';
            const w = window.open(url, '_blank');
            // 某些浏览器会拦截弹窗：拦截时退化为当前页打开
            if (!w) {
                window.location.href = url;
            }
        };
    }
</script>
