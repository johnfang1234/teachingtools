    // 🆕 智能多级检测比例尺：根据组卡片容器剩余空间，给超长名字自动精准降低字号防溢出
    function recalculateGroupNamesFontScale() {
        const badges = document.querySelectorAll('.grpmkr-student-badge');
        badges.forEach(badge => {
            let baseSize = 24; // 设定的大初始标准字号
            badge.style.fontSize = `${baseSize}px`;
            
            // 构建微型虚拟虚拟宽度探针进行长名字防破位折叠微调
            let textLen = badge.textContent.length;
            if (textLen > 9) {
                let scaledSize = Math.max(14, baseSize - (textLen - 8) * 1.5);
                badge.style.fontSize = `${scaledSize}px`;
            }
        });
    }

    // ── 🆕 智能物理排座小组抽取系统 (Pick Group 核心改良) ──
    document.getElementById('pickGroupBtn').onclick = () => {
        if (isRolling) return;

        // 只统计有颜色标记的座位
        const allCards = seatList.filter(s => s.el.className.split(' ').some(c => c.startsWith('gc')));
        if (allCards.length === 0) return;

        // 辅助：判断座位是否有学生名字
        function hasName(s) { return s.el.querySelector('.seat-name').innerText.trim() !== ''; }

        // 辅助：通用抽取动画驱动（传入分组Map，key→seats数组）
        function runGroupPick(groupMap, historyPrefix) {
            // 过滤掉所有组员都没有名字的空组
            const validKeys = Object.keys(groupMap).filter(k => groupMap[k].some(hasName));
            if (validKeys.length === 0) return;

            let unpicked = validKeys.filter(k => !pickedPhysicalGroupsHistory.includes(historyPrefix + k));
            if (unpicked.length === 0) { pickedPhysicalGroupsHistory = []; unpicked = [...validKeys]; }

            isRolling = true;
            let duration = 1200, intervalTime = 80, elapsed = 0;
            seatList.forEach(s => s.el.classList.remove('group-rolling', 'group-selected', 'pick-rolling'));

            const grpTimer = setInterval(() => {
                playTickSound();
                seatList.forEach(s => s.el.classList.remove('group-rolling'));
                const randKey = validKeys[Math.floor(Math.random() * validKeys.length)];
                groupMap[randKey].forEach(s => s.el.classList.add('group-rolling'));
                elapsed += intervalTime;
                if (elapsed >= duration) {
                    clearInterval(grpTimer);
                    const winnerKey = unpicked[Math.floor(Math.random() * unpicked.length)];
                    pickedPhysicalGroupsHistory.push(historyPrefix + winnerKey);
                    seatList.forEach(s => s.el.classList.remove('group-rolling'));
                    groupMap[winnerKey].forEach(s => s.el.classList.add('group-selected'));
                    playSuccessSound();
                    isRolling = false;
                }
            }, intervalTime);
        }

        if (currentMode === 'm3') {
            // Rows of 2：每对 = 同一列（大X桶）+ 同一行（Y桶）的两个相邻座位
            // layoutDoublePair中，同对两座位X差约 pairGap(~1%bw)，不同列X差约 colGap(~7%bw)
            // 用宽桶(seatBox宽度/6)来区分列，小桶区分行
            const bw = seatBox.clientWidth || 1000;
            const colBucketSize = bw / 3.5; // 3列，每列宽约 bw/3，用除以3.5保证同列归一桶
            const rowBucketSize = 15;
            const pairMap = {};
            allCards.forEach(s => {
                const colKey = Math.floor(s.x / colBucketSize);
                const rowKey = Math.round(s.y / rowBucketSize);
                const key = colKey + '_' + rowKey;
                if (!pairMap[key]) pairMap[key] = [];
                pairMap[key].push(s);
            });
            runGroupPick(pairMap, 'pair_');
            return;
        }

        if (currentMode === 'm4') {
            // Rows of 3：layoutThreeRow中每行3座位共享同一gc颜色，按颜色类分组即得3人组
            // 但同一颜色可能跨左右两侧各出现一次（gIdx循环），需结合X位置区分左右侧
            const bw = seatBox.clientWidth || 1000;
            const mid = bw / 2;
            const rowMap = {};
            allCards.forEach(s => {
                const gcClass = s.el.className.split(' ').find(c => c.startsWith('gc'));
                const side = s.x < mid ? 'L' : 'R';
                const key = side + '_' + gcClass;
                if (!rowMap[key]) rowMap[key] = [];
                rowMap[key].push(s);
            });
            runGroupPick(rowMap, 'row3_');
            return;
        }

        if (currentMode === 'm1') {
            // Groups of 4：每个gc颜色对应4座位（一个2×2方阵）
            const grpMap = {};
            allCards.forEach(s => {
                const gc = s.el.className.split(' ').find(c => c.startsWith('gc'));
                if (!grpMap[gc]) grpMap[gc] = [];
                grpMap[gc].push(s);
            });
            runGroupPick(grpMap, 'grp4_');
            return;
        }

        if (currentMode === 'm2') {
            // Groups of 6：每个gc颜色对应6座位（一个2×3方阵）
            const grpMap = {};
            allCards.forEach(s => {
                const gc = s.el.className.split(' ').find(c => c.startsWith('gc'));
                if (!grpMap[gc]) grpMap[gc] = [];
                grpMap[gc].push(s);
            });
            runGroupPick(grpMap, 'grp6_');
            return;
        }

        // custom 模式：按颜色分组
        const grpMap = {};
        allCards.forEach(s => {
            const gc = s.el.className.split(' ').find(c => c.startsWith('gc'));
            if (!grpMap[gc]) grpMap[gc] = [];
            grpMap[gc].push(s);
        });
        runGroupPick(grpMap, 'grpc_');
    };

