    // 手动删减最后一个小组并将其中的学生自动释放回前端兜底组
    document.getElementById('btnGroupRemove').onclick = () => {
        if (currentActiveGroupsData.length <= 1) return;
        const removedStudents = currentActiveGroupsData.pop();
        customGroupNames.pop(); // keep names in sync
        if (removedStudents && removedStudents.length > 0) {
            currentActiveGroupsData[0] = currentActiveGroupsData[0].concat(removedStudents);
        }
        renderGroupBlocks();
    };

    // 智能渲染小组区块与拖放事件挂载
    function renderGroupBlocks() {
        grpmkrContainer.innerHTML = '';
        if (currentActiveGroupsData.length === 0) {
            grpmkrContainer.innerHTML = '<div style="color:#64748b; font-weight:bold; font-size: 20px; padding:20px;">No students available on the seating chart.</div>';
            return;
        }
        
        const cardBgColors = ['#FA9CB5', '#6EE1C6', '#F8BF6F', '#73C2FB', '#A2E16F', '#F78665'];
        const cardTextColors = ['#8f1a39', '#115947', '#734605', '#164870', '#3b5c1a', '#852408'];
        
        currentActiveGroupsData.forEach((groupStudents, gIdx) => {
            const card = document.createElement('div');
            card.className = 'grpmkr-card';
            card.dataset.gidx = gIdx;
            
            const colorPos = gIdx % 6;
            card.style.backgroundColor = cardBgColors[colorPos];
            card.style.color = cardTextColors[colorPos];
            
            const title = document.createElement('div');
            title.className = 'grpmkr-card-title';
            
            // Editable group name span
            const nameSpan = document.createElement('span');
            nameSpan.className = 'grpmkr-group-name';
            nameSpan.textContent = customGroupNames[gIdx] || `Group ${gIdx + 1}`;
            nameSpan.title = 'Click to rename';
            nameSpan.style.cursor = 'pointer';
            nameSpan.style.paddingBottom = '1px';
            nameSpan.onclick = () => {
                const input = document.createElement('input');
                input.type = 'text';
                input.value = nameSpan.textContent;
                input.style.cssText = 'font-size:inherit;font-weight:inherit;font-family:inherit;color:inherit;background:rgba(255,255,255,0.5);border:none;border-bottom:2px solid currentColor;outline:none;width:120px;padding:0 2px;';
                nameSpan.replaceWith(input);
                input.focus(); input.select();
                function commit() {
                    const val = input.value.trim() || `Group ${gIdx + 1}`;
                    customGroupNames[gIdx] = val;
                    input.replaceWith(nameSpan);
                    nameSpan.textContent = val;
                }
                input.onblur = commit;
                input.onkeydown = e => { if (e.key === 'Enter') { e.preventDefault(); input.blur(); } if (e.key === 'Escape') { input.value = nameSpan.textContent; input.blur(); } };
            };

            const countSpan = document.createElement('span');
            countSpan.className = 'gcount-tag';
            countSpan.textContent = `👥 ${groupStudents.length}`;
            title.appendChild(nameSpan);
            title.appendChild(countSpan);
            card.appendChild(title);
            
            const listContainer = document.createElement('div');
            listContainer.className = 'grpmkr-student-list';
            
            // 挂载HTML5原生态高级拖放网格目的地
            listContainer.addEventListener('dragover', (e) => {
                e.preventDefault();
                card.classList.add('dragover');
            });
            listContainer.addEventListener('dragleave', () => card.classList.remove('dragover'));
            listContainer.addEventListener('drop', (e) => {
                e.preventDefault();
                card.classList.remove('dragover');
                const dragData = e.dataTransfer.getData('text/plain');
                if (!dragData) return;
                const [sourceGidx, rawName] = dragData.split(':::');
                const targetGidx = parseInt(card.dataset.gidx);
                const sIdx = parseInt(sourceGidx);
                
                if (sIdx === targetGidx) return; // 同组拒绝执行
                
                // 严格核心数组边界联动剔除并追加迁移
                const originalSourceArr = currentActiveGroupsData[sIdx];
                const namePosition = originalSourceArr.indexOf(rawName);
                if (namePosition !== -1) {
                    originalSourceArr.splice(namePosition, 1);
                    currentActiveGroupsData[targetGidx].push(rawName);
                    renderGroupBlocks(); // 刷新同步画面
                }
            });
            
            groupStudents.forEach(stu => {
                const badge = document.createElement('div');
                badge.className = 'grpmkr-student-badge';
                badge.textContent = stu;
                badge.setAttribute('draggable', 'true');
                
                // 挂载拖拽发起事件
                badge.addEventListener('dragstart', (e) => {
                    badge.classList.add('dragging');
                    e.dataTransfer.setData('text/plain', `${gIdx}:::${stu}`);
                });
                badge.addEventListener('dragend', () => badge.classList.remove('dragging'));
                
                listContainer.appendChild(badge);
            });
            
            card.appendChild(listContainer);
            grpmkrContainer.appendChild(card);
        });
        
        // 动态执行字号智能自适应无损缩放
        recalculateGroupNamesFontScale();
