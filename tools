    function onPointerDown(e) {
        if (currentMode !== 'custom') { seatClickSwap(this); return; }
        e.preventDefault(); dragElement = this; pointerId = e.pointerId; dragElement.classList.add('dragging'); dragElement.setPointerCapture(pointerId);
        startX = e.clientX; startY = e.clientY; originalLeft = parseFloat(dragElement.style.left); originalTop = parseFloat(dragElement.style.top);
        dragElement.addEventListener('pointermove', onPointerMove); dragElement.addEventListener('pointerup', onPointerUp); dragElement.addEventListener('pointercancel', onPointerUp);
    }

    function onPointerMove(e) {
        if (!dragElement || e.pointerId !== pointerId) return;
        let dx = e.clientX - startX; let dy = e.clientY - startY;
        if (flipped) { dx = -dx; dy = -dy; }
        let targetLeft = originalLeft + dx; let targetTop = originalTop + dy;
        const bw = seatBox.clientWidth; const bh = seatBox.clientHeight;
        const item = seatList.find(s => s.el === dragElement); if (!item) return;

        seatList.forEach(other => {
            if (other.el === dragElement) return;
            if (Math.abs(targetLeft - other.x) < snapThreshold) { targetLeft = other.x; } 
            else if (Math.abs((targetLeft + item.w) - (other.x + other.w)) < snapThreshold) { targetLeft = other.x + other.w - item.w; } 
            else if (Math.abs(targetLeft - (other.x + other.w)) < snapThreshold) { targetLeft = other.x + other.w; } 
            else if (Math.abs((targetLeft + item.w) - other.x) < snapThreshold) { targetLeft = other.x - item.w; }
            if (Math.abs(targetTop - other.y) < snapThreshold) { targetTop = other.y; } 
            else if (Math.abs((targetTop + item.h) - (other.y + other.h)) < snapThreshold) { targetTop = other.y + other.h - item.h; } 
            else if (Math.abs(targetTop - (other.y + other.h)) < snapThreshold) { targetTop = other.y + other.h; } 
            else if (Math.abs((targetTop + item.h) - other.y) < snapThreshold) { targetTop = other.y - item.h; }
        });
        targetLeft = Math.max(0, Math.min(targetLeft, bw - item.w)); targetTop = Math.max(0, Math.min(targetTop, bh - item.h));
        dragElement.style.left = `${targetLeft}px`; dragElement.style.top = `${targetTop}px`;
        item.x = targetLeft; item.y = targetTop;
    }

    function onPointerUp(e) {
        if (!dragElement || e.pointerId !== pointerId) return;
        dragElement.classList.remove('dragging'); dragElement.releasePointerCapture(pointerId);
        dragElement.removeEventListener('pointermove', onPointerMove); dragElement.removeEventListener('pointerup', onPointerUp); dragElement.removeEventListener('pointercancel', onPointerUp);
