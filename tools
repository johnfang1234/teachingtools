    // ── 使用 visibilitychange + 时间戳补偿，确保切换页面后计时继续 ──
    let timerStartWallTime = null; // 计时器启动时的系统时间戳
    let timerSecondsAtStart = 0;   // 启动时剩余秒数快照

    function startTimerWorker() {
        if (timerInterval) return;
        if (timerTotalSeconds <= 0) return;
        timerStartWallTime = Date.now();
        timerSecondsAtStart = timerTotalSeconds;
        timerInterval = setInterval(timerTick, 1000);
    }

    function timerTick() {
        // 用真实时间差补偿节流误差
        const elapsed = Math.round((Date.now() - timerStartWallTime) / 1000);
        timerTotalSeconds = Math.max(0, timerSecondsAtStart - elapsed);
        updateTimerDisplay();
        if (timerTotalSeconds <= 0) {
            clearInterval(timerInterval);
            timerInterval = null;
            timerStartWallTime = null;
            playSuccessSound();
            alert("Time's up!");
        }
    }

    // 离开页面时记录时间戳；回来时立刻补算差值
    document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') {
            // 页面隐藏：记录当前剩余秒数和时间戳到 sessionStorage
            if (timerInterval) {
                sessionStorage.setItem('timer_snapshot_sec', timerTotalSeconds);
                sessionStorage.setItem('timer_snapshot_ts', Date.now());
            }
        } else {
            // 页面回到前台：检查是否有进行中的倒计时
            const snapshotSec = sessionStorage.getItem('timer_snapshot_sec');
            const snapshotTs = sessionStorage.getItem('timer_snapshot_ts');
            if (snapshotSec !== null && snapshotTs !== null && timerInterval) {
                const elapsed = Math.round((Date.now() - parseInt(snapshotTs)) / 1000);
                timerTotalSeconds = Math.max(0, parseInt(snapshotSec) - elapsed);
                timerSecondsAtStart = timerTotalSeconds;
                timerStartWallTime = Date.now();
                updateTimerDisplay();
                sessionStorage.removeItem('timer_snapshot_sec');
                sessionStorage.removeItem('timer_snapshot_ts');
                if (timerTotalSeconds <= 0) {
                    clearInterval(timerInterval);
                    timerInterval = null;
                    playSuccessSound();
                    alert("Time's up!");
                }
            }
        }
    });

